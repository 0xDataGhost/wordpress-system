# ── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
# Base path for all business/API routes (the /health endpoint is always at root)
API_PREFIX=/api/v1
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all.
CORS_ORIGIN=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_dashboard
DB_POOL_MAX=10
# Max wait (ms) to acquire a connection before failing fast.
DB_CONNECTION_TIMEOUT_MS=10000
# Idle connections are released after this many ms (0 disables).
DB_IDLE_TIMEOUT_MS=30000

# ── Redis (shared by the app cache and BullMQ) ────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────────────────────
# Cost factor for bcrypt password hashing (10–15).
BCRYPT_ROUNDS=12
# Secrets for signing JWTs — use long random values, distinct per type.
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_dev_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_dev_refresh_secret_at_least_32_chars
# Access tokens are short-lived; refresh tokens are long-lived and rotated.
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Auth rate limiting (Redis-backed) ─────────────────────────
# Per-IP fixed window applied to login / register / refresh, each with its own
# bucket. Set to false to disable (e.g. for load testing). Window is in seconds;
# max is the number of requests allowed per window before a 429 RATE_LIMITED.
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_MAX=10

# ── WooCommerce sync & outbound delivery ──────────────────────
# Encrypts the connector API key at rest so the SaaS can sign outbound requests
# to WordPress (product publish + WooCommerce pull sync). 32 bytes as 64 hex
# chars or base64. Generate with: openssl rand -hex 32
# When UNSET, outbound delivery is disabled: publish and sync return a clear
# "not configured" error instead of silently failing. Keys generated before this
# is set must be re-generated from the dashboard to enable outbound delivery.
CONNECTOR_ENCRYPTION_KEY=
# Timeout (ms) for outbound HTTP calls from the SaaS to a WordPress connector.
WP_HTTP_TIMEOUT_MS=20000
# Page size and per-entity page cap used when pulling WooCommerce data on sync.
SYNC_PAGE_SIZE=50
SYNC_MAX_PAGES=200

# ── Dashboard analytics ───────────────────────────────────────
# Redis read-through cache TTL (seconds, 0–3600) for the dashboard endpoints.
DASHBOARD_CACHE_TTL_SECONDS=300
# A product is "low stock" when active and stock_quantity <= this threshold.
DASHBOARD_LOW_STOCK_THRESHOLD=5

# ── AI assistants (Phase 12.5) ────────────────────────────────
# When OPENAI_API_KEY is UNSET the AI module falls back to a deterministic mock
# provider, so the API boots and the assistants work offline. Set the key to
# switch to live generation with no code changes.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# Timeout (ms) for outbound AI provider calls.
AI_REQUEST_TIMEOUT_MS=30000

# ── Digital code inventory (Phase 16) ─────────────────────────
# Digital codes are sensitive financial inventory. The raw code is NEVER stored:
# it is encrypted at rest with AES-256-GCM, and duplicates are detected via a
# keyed HMAC-SHA256 fingerprint. Both keys live ONLY here, never in the database.
# ENCRYPTION_KEY: 32 bytes as 64 hex chars or base64.  Generate: openssl rand -hex 32
# HASH_KEY: a strong random secret for the fingerprint. Generate: openssl rand -hex 32
# Optional today (the digital module isn't wired yet); the import path will
# require both once digital fulfillment is used.
DIGITAL_CODE_ENCRYPTION_KEY=
DIGITAL_CODE_HASH_KEY=

# ── Graceful shutdown ─────────────────────────────────────────
SHUTDOWN_TIMEOUT_MS=10000
